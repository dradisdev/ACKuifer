# ACKuifer .gitignore

# ============================================================
# SECRETS — never commit these
# ============================================================
.env
.env.local
.env.*.local

# ============================================================
# PYTHON
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
*.egg-info/
dist/
build/
.eggs/
*.egg
pip-wheel-metadata/
*.pyo

# ============================================================
# PYTEST / TESTING
# ============================================================
.pytest_cache/
.coverage
htmlcov/
.tox/

# ============================================================
# PLAYWRIGHT
# ============================================================
# Playwright browser binaries are large — install locally via
# `playwright install chromium`, don't commit
playwright-browsers/

# ============================================================
# DATABASE
# ============================================================
*.sqlite3
*.db

# ============================================================
# LOGS
# ============================================================
*.log
logs/

# ============================================================
# OS FILES
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ============================================================
# EDITORS
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================
# NODE (Claude Code uses Node internally)
# ============================================================
node_modules/
npm-debug.log*

# ============================================================
# DATA FILES (large GeoJSON — keep in repo but note size)
# ============================================================
# data/ files ARE committed — they are required reference assets.
# If any become too large for GitHub (>50MB), use Git LFS.
# data/*.geojson  <-- intentionally NOT ignored

# ============================================================
# PROTOTYPE OUTPUT / SCRATCH
# ============================================================
# Raw downloaded PDFs from MassDEP (transient, not committed)
prototype/downloads/
prototype/*.pdf
.claude/
prototype/pfas_monitor/pdfs/
~$*
