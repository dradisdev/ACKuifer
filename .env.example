# ACKuifer Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ============================================================
# DATABASE
# ============================================================
# Railway provides this automatically when you add a Postgres plugin.
# For local dev, use your local Postgres connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# ============================================================
# SECURITY
# ============================================================
# Admin interface password (set a strong random string)
ADMIN_PASSWORD=your_admin_password_here

# Secret key for signing tokenized links (manage subscriptions, unsubscribe)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# ============================================================
# EMAIL (Resend)
# ============================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Verified sending domain — must match your Resend domain setup
EMAIL_FROM=alerts@ackuifer.org

# ============================================================
# SMS (Twilio)
# ============================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ============================================================
# MAPBOX
# ============================================================
# Public token — safe to use in frontend JS
MAPBOX_PUBLIC_TOKEN=pk.eyxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# OPERATOR SETTINGS
# ============================================================
# Email address for dead man's switch alerts and operator notifications
OPERATOR_EMAIL=your_email@example.com

# Number of days without a successful scraper run before admin alert fires
# Default: 10
DEADMANS_WINDOW_DAYS=10

# ============================================================
# SCRAPER SCHEDULE (Railway cron syntax)
# ============================================================
# How often to run the Laserfiche scraper (Railway cron format)
LASERFICHE_CRON_SCHEDULE=0 8 * * *

# How often to run the MassDEP Source Discovery monitor
MASSDEP_CRON_SCHEDULE=0 9 * * *

# ============================================================
# RAILWAY (set automatically by Railway — do not set manually)
# ============================================================
# PORT=8000
# RAILWAY_ENVIRONMENT=production
